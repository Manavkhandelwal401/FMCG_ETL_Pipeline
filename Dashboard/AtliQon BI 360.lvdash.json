    {
      "name": "top_10_products",
      "displayName": "Top 10 Products",
      "queryLines": [
        "WITH top_products AS (\n",
        "  SELECT\n",
        "    product\n",
        "  FROM\n",
        "    fmcg.gold.vw_fact_orders_enriched\n",
        "  GROUP BY\n",
        "    product\n",
        "  ORDER BY\n",
        "    SUM(total_amount_inr) DESC\n",
        "  LIMIT 10\n",
        ")\n",
        "SELECT\n",
        "  f.year,\n",
        "  f.quarter,\n",
        "  f.month_name,\n",
        "  f.category,\n",
        "  f.channel,\n",
        "  f.product,\n",
        "  f.total_amount_inr,\n",
        "  f.sold_quantity\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched f\n",
        "    INNER JOIN top_products tp\n",
        "      ON f.product = tp.product"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    }
  ],
